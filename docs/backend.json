
{
  "entities": {
    "DashboardSummary": {
      "title": "DashboardSummary",
      "type": "object",
      "description": "Pre-computed counters for role-specific dashboards to prevent collection scans.",
      "properties": {
        "totalCharters": { "type": "number" },
        "pendingRequests": { "type": "number" },
        "confirmedTrips": { "type": "number" },
        "revenueThisMonth": { "type": "number" },
        "seatRequestsPending": { "type": "number" },
        "accommodationRequestsPending": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "MonthlyReport": {
      "title": "MonthlyReport",
      "type": "object",
      "description": "Pre-aggregated monthly performance metrics.",
      "properties": {
        "revenue": { "type": "number" },
        "commission": { "type": "number" },
        "trips": { "type": "number" },
        "seatSales": { "type": "number" },
        "accommodationBookings": { "type": "number" },
        "period": { "type": "string", "description": "YYYYMM format" }
      }
    },
    "CharterRFQ": {
      "title": "CharterRFQ",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "operatorId": { "type": "string" },
        "agencyId": { "type": "string" },
        "corporateId": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/dashboardSummary",
        "definition": { "entityName": "DashboardSummary", "description": "Personal counters for customers." }
      },
      {
        "path": "/operators/{operatorId}/dashboardSummary",
        "definition": { "entityName": "DashboardSummary", "description": "Operational counters for NSOP holders." }
      },
      {
        "path": "/agencies/{agencyId}/dashboardSummary",
        "definition": { "entityName": "DashboardSummary", "description": "Commercial counters for distributors." }
      },
      {
        "path": "/corporates/{corporateId}/dashboardSummary",
        "definition": { "entityName": "DashboardSummary", "description": "Governance counters for corporate desks." }
      },
      {
        "path": "/reports/{reportId}",
        "definition": { "entityName": "MonthlyReport", "description": "Aggregated analytics nodes." }
      },
      {
        "path": "/operators/{operatorId}/charterRequests/{requestId}",
        "definition": { "entityName": "CharterRFQ", "description": "Operator-scoped charter views." }
      },
      {
        "path": "/users/{userId}/charterRequests/{requestId}",
        "definition": { "entityName": "CharterRFQ", "description": "Customer-scoped charter views." }
      }
    ]
  }
}
