
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for optimized lookups
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isPlatformAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/platformAdmins/$(request.auth.uid)); }

    // Scoped Data Access: Enforce ownership at the root of the path
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId) || isPlatformAdmin();
    }

    match /operators/{operatorId}/{allPaths=**} {
      allow read, write: if isOwner(operatorId) || isPlatformAdmin();
    }

    match /agencies/{agencyId}/{allPaths=**} {
      allow read, write: if isOwner(agencyId) || isPlatformAdmin();
    }

    match /corporates/{corporateId}/{allPaths=**} {
      allow read, write: if isOwner(corporateId) || isPlatformAdmin();
    }

    match /hotelPartners/{hotelPartnerId}/{allPaths=**} {
      allow read, write: if isOwner(hotelPartnerId) || isPlatformAdmin();
    }

    // Reports: Pre-aggregated read access
    match /reports/{reportId} {
      allow read: if isSignedIn() && (reportId.startsWith(request.auth.uid) || isPlatformAdmin());
      allow write: if false; // Only system-level updates
    }

    // Empty Legs: Marketplace visibility
    match /emptyLegFlights/{flightId} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin() || (isSignedIn() && request.resource.data.operatorId == request.auth.uid);
    }

    // Platform Admins: Role mapping
    match /platformAdmins/{adminId} {
      allow read: if isOwner(adminId) || isPlatformAdmin();
      allow write: if isPlatformAdmin();
    }
  }
}
