rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for optimized lookups
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/platformAdmins/$(request.auth.uid)); }

    // Admin-Only Modules
    match /platformChargeRules/{ruleId} {
      allow read, write: if isAdmin();
    }
    match /adminAuditLogs/{logId} {
      allow read, write: if isAdmin();
    }
    match /systemAlerts/{alertId} {
      allow read, write: if isAdmin();
    }
    match /userActivityLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isSignedIn(); // Users can write their own activity
    }

    // Scoped Data Access: Enforce ownership at the root of the path
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /operators/{operatorId}/{allPaths=**} {
      allow read, write: if isOwner(operatorId) || isAdmin();
    }

    match /travelAgencies/{agencyId}/{allPaths=**} {
      allow read, write: if isOwner(agencyId) || isAdmin();
    }

    match /corporateOrganizations/{corpId}/{allPaths=**} {
      allow read, write: if isOwner(corpId) || isAdmin();
    }

    match /hotelPartners/{hotelPartnerId}/{allPaths=**} {
      allow read, write: if isOwner(hotelPartnerId) || isAdmin();
    }

    // Marketplace collections
    match /charterRequests/{requestId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /seatAllocationRequests/{requestId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /emptyLegFlights/{flightId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.resource.data.operatorId == request.auth.uid);
    }

    // Platform Admins: Role mapping
    match /platformAdmins/{adminId} {
      allow read: if isOwner(adminId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
