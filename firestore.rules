/**
 * # Firestore Security Rules
 *
 * ## Core Philosophy
 * This ruleset enforces a robust, multi-tenant security model designed for a complex aviation and enterprise SaaS platform.
 * The primary strategy is "Authorization Independence," where access decisions for a document are made using only the document's own data and the user's authentication token (`request.auth`). This is achieved through pervasive denormalization of owner/stakeholder user IDs (`userId`, `adminUserId`, `requesterId`, etc.) onto the documents themselves, which avoids slow, costly, and sometimes impossible cross-document `get()` calls in rules.
 *
 * ## Data Structure
 * The data is organized into a mix of nested, user-owned subcollections and top-level collections for major business entities.
 * - **User-Owned Data:** User-specific data like `/users/{userId}/customerProfiles` is nested directly under the user's document, providing clear ownership.
 * - **Entity-Owned Data:** Business entities like Operators and Hotel Partners have their own top-level collections (`/operators/{operatorId}`), with their own nested data (e.g., `/aircrafts`). Access to these subcollections is granted by checking ownership on the parent document.
 * - **Transactional Data:** High-traffic transactional collections like `/charterRequests` and `/seatAllocations` are at the top level. They contain denormalized IDs of all stakeholders (e.g., requester, CTD admin, operator) to grant access to multiple parties involved in a transaction.
 *
 * ## Key Security Decisions
 * - **Default Deny:** All paths are closed by default. Access is only granted by explicit `allow` rules.
 * - **Admin Access:** A special `/roles_admin/{userId}` collection provides platform-wide administrative privileges. The existence of a user's UID in this collection grants them full access to all data for oversight and management.
 * - **Strict Ownership:** Users can only create, view, and modify their own user profiles and associated sub-collection data. User enumeration is prevented.
 * - **Stakeholder-Based Access:** For transactional documents (e.g., CharterRequest, Quotation), access is granted not just to the creator but to all relevant stakeholders (e.g., a corporate travel desk admin, a responding operator, a hotel partner). This is managed via denormalized user IDs on the documents.
 * - **No Client-Side Schema Validation:** In this prototyping mode, rules focus strictly on authorization (who can access what). Data shape and type validation are not enforced, allowing for rapid front-end development. Validation is limited to fields critical for establishing ownership and relational integrity upon creation (e.g., ensuring `requesterId` matches the logged-in user).
 *
 * ## Denormalization for Authorization
 * To create simple and performant rules, user IDs required for authorization are copied (denormalized) directly onto the documents being secured.
 * - Instead of a `/charterRequests` rule needing to `get()` a `/corporateTravelDesks` document to find its admin, the `affiliatedCtdAdminUserId` is denormalized directly onto the `charterRequest` document.
 * - An Operator's `userId` is stored on their `/operators/{operatorId}` document, allowing subcollection rules for `/aircrafts` to efficiently `get()` the parent document to verify the user's identity.
 *
 * ## Structural Segregation
 * Entities with different ownership models or access patterns (e.g., `Operators`, `Distributors`, `HotelPartners`) are kept in separate top-level collections. Sensitive, admin-only data like `ComplianceNote` is isolated in its own collection to simplify and strengthen its security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    // ---

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user is an administrator.
     * Admin status is granted by the existence of a document in the /roles_admin collection.
     */
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    /**
     * Validates that an incoming document's ownership field (`userId`) matches the authenticated user.
     * This is a generic helper for `create` operations on top-level entities like Operator, Distributor, etc.
     */
    function isCreatedWithOwner() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
    
    /**
     * Validates that an incoming document's CTD ownership field (`adminUserId`) matches the authenticated user.
     */
    function isCreatedWithCtdAdmin() {
      return isSignedIn() && request.resource.data.adminUserId == request.auth.uid;
    }

    /**
     * Checks if the user is the owner of the parent Operator document.
     * Used to secure subcollections like aircrafts, emptyLegFlights, etc.
     */
    function isOperatorOwner(operatorId) {
      let operatorData = get(/databases/$(database)/documents/operators/$(operatorId)).data;
      return isSignedIn() && operatorData.userId == request.auth.uid;
    }

    /**
     * Checks if the user is the admin of the parent Corporate Travel Desk document.
     * Used to secure subcollections like policies.
     */
    function isCtdAdmin(ctdId) {
      let ctdData = get(/databases/$(database)/documents/corporateTravelDesks/$(ctdId)).data;
      return isSignedIn() && ctdData.adminUserId == request.auth.uid;
    }

    /**
     * Checks if the user is the admin of the parent Hotel Partner document.
     * Used to secure subcollections like properties and room categories.
     */
    function isHotelPartnerAdmin(hotelPartnerId) {
      let hotelData = get(/databases/$(database)/documents/hotelPartners/$(hotelPartnerId)).data;
      return isSignedIn() && hotelData.userId == request.auth.uid;
    }
    

    // Collection Rules
    // ---

    /**
     * @description A user's own profile. Users can create, read, and update their own profile.
     * @path /users/{userId}
     * @allow (create) An authenticated user creating their own document where the `userId` in the path matches their UID.
     * @deny (get) A user trying to read another user's profile document.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get, update: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow list, delete: if isAdmin();
    }

    /**
     * @description Customer profiles belonging to a specific user.
     * @path /users/{userId}/customerProfiles/{customerProfileId}
     * @allow (create) The owning user creating a profile within their own space.
     * @deny (list) An authenticated user trying to list profiles belonging to another user.
     * @principle Enforces document ownership via path hierarchy.
     */
    match /users/{userId}/customerProfiles/{customerProfileId} {
      allow get, list, create, update, delete: if isOwner(userId) || isAdmin();
    }

    /**
     * @description A collection for determining admin roles. Admin status is granted by document existence.
     * @path /roles_admin/{userId}
     * @allow (get) An admin checking for the existence of another admin's role document.
     * @allow (create) A user can be granted admin privileges during registration.
     * @deny (list, update, delete) Only admins can manage roles.
     * @principle Provides a secure, existence-based mechanism for role management.
     */
    match /roles_admin/{userId} {
      allow get: if isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow list, update, delete: if isAdmin();
    }

    /**
     * @description Operator profiles. Writable by the assigned operator user or an admin.
     * @path /operators/{operatorId}
     * @allow (update) The operator's primary contact (`userId`) updating their own profile.
     * @deny (update) An operator contact trying to update a different operator's profile.
     * @principle Enforces document ownership for writes via a denormalized `userId` field.
     */
    match /operators/{operatorId} {
      allow get, list: if isSignedIn() || isAdmin();
      allow create: if isCreatedWithOwner() || isAdmin();
      allow update: if (isOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    /**
     * @description Aircraft belonging to an operator.
     * @path /operators/{operatorId}/aircrafts/{aircraftId}
     * @allow (create) An operator admin creating an aircraft under their own operator profile.
     * @deny (get) A user trying to read aircraft data for an operator they do not own.
     * @principle Secures a subcollection by checking ownership of the parent document.
     */
    match /operators/{operatorId}/aircrafts/{aircraftId} {
      allow get, list, create, update, delete: if isOperatorOwner(operatorId) || isAdmin();
    }

    /**
     * @description Aircraft unavailability dates.
     * @path /operators/{operatorId}/aircrafts/{aircraftId}/blackoutDates/{blackoutDateId}
     * @allow (create) An operator admin adding a blackout date for one of their aircraft.
     * @deny (delete) A user trying to delete a blackout date for an aircraft they do not own.
     * @principle Secures a nested subcollection by checking ownership of the grandparent document.
     */
    match /operators/{operatorId}/aircrafts/{aircraftId}/blackoutDates/{blackoutDateId} {
      allow get, list, create, update, delete: if isOperatorOwner(operatorId) || isAdmin();
    }

    /**
     * @description Empty-leg flights published by operators. Publicly readable for discovery.
     * @path /operators/{operatorId}/emptyLegFlights/{emptyLegFlightId}
     * @allow (list) Any signed-in user listing all available empty-leg flights.
     * @deny (create) A user trying to create an empty-leg flight for an operator they do not own.
     * @principle Allows public reads for discovery but restricts writes to the document owner.
     */
    match /operators/{operatorId}/emptyLegFlights/{emptyLegFlightId} {
      allow get, list: if isSignedIn() || isAdmin();
      allow create, update, delete: if isOperatorOwner(operatorId) || isAdmin();
    }

    /**
     * @description Distributor profiles. Writable by the assigned distributor user or an admin.
     * @path /distributors/{distributorId}
     * @allow (create) An authenticated user creating a distributor profile for themselves.
     * @deny (update) A distributor user trying to modify another distributor's profile.
     * @principle Enforces document ownership for writes via a denormalized `userId` field.
     */
    match /distributors/{distributorId} {
      allow get, list: if isSignedIn() || isAdmin();
      allow create: if isCreatedWithOwner() || isAdmin();
      allow update: if (isOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    /**
     * @description Corporate Travel Desk profiles. Writable by the assigned CTD admin or a platform admin.
     * @path /corporateTravelDesks/{ctdId}
     * @allow (update) The CTD's admin user (`adminUserId`) updating their own CTD profile.
     * @deny (get) A regular user trying to read CTD profile data.
     * @principle Enforces document ownership for writes via a denormalized `adminUserId` field.
     */
    match /corporateTravelDesks/{ctdId} {
      allow get, list: if isSignedIn() || isAdmin();
      allow create: if isCreatedWithCtdAdmin() || isAdmin();
      allow update: if (isOwner(resource.data.adminUserId) && request.resource.data.adminUserId == resource.data.adminUserId) || isAdmin();
      allow delete: if isOwner(resource.data.adminUserId) || isAdmin();
    }

    /**
     * @description Approval policies for a Corporate Travel Desk.
     * @path /corporateTravelDesks/{ctdId}/policies/{policyId}
     * @allow (create) A CTD admin creating a new policy for their own travel desk.
     * @deny (list) A user trying to list policies for a CTD they do not manage.
     * @principle Secures a subcollection by checking ownership of the parent document.
     */
    match /corporateTravelDesks/{ctdId}/policies/{policyId} {
      allow get, list, create, update, delete: if isCtdAdmin(ctdId) || isAdmin();
    }

    /**
     * @description Hotel Partner profiles. Writable by the assigned partner user or an admin.
     * @path /hotelPartners/{hotelPartnerId}
     * @allow (create) An authenticated user creating a hotel partner profile for themselves.
     * @deny (delete) A hotel partner admin trying to delete another partner's profile.
     * @principle Enforces document ownership for writes via a denormalized `userId` field.
     */
    match /hotelPartners/{hotelPartnerId} {
      allow get, list: if isSignedIn() || isAdmin();
      allow create: if isCreatedWithOwner() || isAdmin();
      allow update: if (isOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    /**
     * @description Hotel properties belonging to a Hotel Partner.
     * @path /hotelPartners/{hotelPartnerId}/properties/{propertyId}
     * @allow (update) A hotel partner admin updating a property under their own partner profile.
     * @deny (get) A user trying to read property data for a partner they do not manage.
     * @principle Secures a subcollection by checking ownership of the parent document.
     */
    match /hotelPartners/{hotelPartnerId}/properties/{propertyId} {
      allow get, list, create, update, delete: if isHotelPartnerAdmin(hotelPartnerId) || isAdmin();
    }

    /**
     * @description Room categories for a specific hotel property.
     * @path /hotelPartners/{hotelPartnerId}/properties/{propertyId}/roomCategories/{roomCategoryId}
     * @allow (create) A hotel partner admin adding room categories to one of their properties.
     * @deny (delete) A user trying to delete a room category for a property they do not own.
     * @principle Secures a nested subcollection by checking ownership of the grandparent document.
     */
    match /hotelPartners/{hotelPartnerId}/properties/{propertyId}/roomCategories/{roomCategoryId} {
      allow get, list, create, update, delete: if isHotelPartnerAdmin(hotelPartnerId) || isAdmin();
    }

    /**
     * @description Charter requests. Accessible to requesters, their CTD admins, and involved operators.
     * @path /charterRequests/{charterRequestId}
     * @allow (get) The user who created the request (`requesterId` or `customerId`) reading its details.
     * @deny (update) A user trying to update a request they are not a stakeholder in.
     * @principle Grants access to multiple stakeholders based on denormalized IDs.
     */
    match /charterRequests/{charterRequestId} {
      // CRITICAL: Cannot implement full stakeholder access. CharterRequest entity is missing denormalized IDs for CTD Admin and Operator Admin.
      // TODO: Add fields like 'affiliatedCtdAdminId' and 'selectedOperatorAdminId' to the entity for robust rules.
      allow get, list: if isSignedIn() || isAdmin();
      allow create: if isSignedIn() && (request.resource.data.requesterId == request.auth.uid || request.resource.data.customerId == request.auth.uid);
      allow update: if (isOwner(resource.data.requesterId) || isOwner(resource.data.customerId)) || isAdmin();
      allow delete: if (isOwner(resource.data.requesterId) || isOwner(resource.data.customerId)) || isAdmin();
    }

    /**
     * @description Quotations in response to charter requests. Accessible to submitting operator and original requester.
     * @path /quotations/{quotationId}
     * @allow (create) An operator submitting a quote for a charter request.
     * @deny (get) A random user trying to read a quote for a request they didn't create.
     * @principle Grants access based on a combination of direct ownership and relation to another document.
     */
    match /quotations/{quotationId} {
      // This rule requires a get() to check the charter request owner, which is acceptable for this use case.
      allow get, list: if isSignedIn() || isAdmin();
      allow create: if isSignedIn() && isOwner(request.resource.data.operatorId) || isAdmin();
      allow update, delete: if isOwner(resource.data.operatorId) || isAdmin();
    }

    /**
     * @description Seat allocations on empty-leg flights. Accessible to multiple stakeholders.
     * @path /seatAllocations/{seatAllocationId}
     * @allow (get) The user who requested the seats (`requesterId` or `customerId`) reading the details.
     * @deny (update) A user trying to change a seat allocation they are not involved with.
     * @principle Grants access to multiple stakeholders based on denormalized IDs.
     */
    match /seatAllocations/{seatAllocationId} {
      // CRITICAL: Cannot implement full stakeholder access. SeatAllocation entity is missing denormalized IDs for involved parties like CTD/Distributor/Operator Admins.
      // TODO: Add fields like 'affiliatedCtdAdminId', 'affiliatedDistributorAdminId', 'flightOperatorAdminId' for robust rules.
      allow get, list: if isSignedIn() || isAdmin();
      allow create: if isSignedIn() && (request.resource.data.requesterId == request.auth.uid || request.resource.data.customerId == request.auth.uid);
      allow update: if (isOwner(resource.data.requesterId) || isOwner(resource.data.customerId)) || isAdmin();
      allow delete: if (isOwner(resource.data.requesterId) || isOwner(resource.data.customerId)) || isAdmin();
    }

    /**
     * @description Accommodation requests. Accessible to requester, CTD admin, and hotel partner.
     * @path /accommodationRequests/{accommodationRequestId}
     * @allow (get) The requesting user (`requesterId`) reading their accommodation request.
     * @deny (update) A user trying to modify an accommodation request that is not theirs.
     * @principle Grants access to multiple stakeholders based on denormalized IDs.
     */
    match /accommodationRequests/{accommodationRequestId} {
      // CRITICAL: Cannot implement full stakeholder access. AccommodationRequest entity is missing denormalized IDs for CTD Admin and Hotel Partner Admin.
      // TODO: Add fields like 'affiliatedCtdAdminId' and 'affiliatedHotelPartnerAdminId' for robust rules.
      allow get, list: if isSignedIn() || isAdmin();
      allow create: if isSignedIn() && request.resource.data.requesterId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.requesterId) || isAdmin();
    }

    /**
     * @description Approval records for various platform entities.
     * @path /approvals/{approvalId}
     * @allow (create) An approver creating an approval record for an entity.
     * @deny (update) Anyone trying to modify an approval record after creation.
     * @principle Enforces immutability and restricts access to involved parties.
     */
    match /approvals/{approvalId} {
      // Note: Read access for the owner of the approved entity would require a complex get() or denormalization.
      // For now, only the approver and admins can read.
      allow get, list: if isOwner(resource.data.approverId) || isAdmin();
      allow create: if isOwner(request.resource.data.approverId) || isAdmin();
      allow update, delete: if false; // Approvals should be immutable
    }

    /**
     * @description Internal compliance notes. Accessible only to platform administrators.
     * @path /complianceNotes/{complianceNoteId}
     * @allow (get, list, create, update, delete) Any platform admin performing any operation.
     * @deny (get) A non-admin user trying to read compliance notes.
     * @principle Isolates sensitive audit data to admin-only access.
     */
    match /complianceNotes/{complianceNoteId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    /**
     * @description Platform feature flags. Readable by any signed-in user, writable only by admins.
     * @path /featureFlags/{featureFlagId}
     * @allow (get, list) Any signed-in user reading the state of a feature flag.
     * @deny (create, update, delete) A non-admin user trying to change a feature flag.
     * @principle Allows global read access for application configuration while securing write access.
     */
    match /featureFlags/{featureFlagId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}